[global]
frame_width = 1
frame_color = "#7c6f64"
separator_color = "#3c3836"
offset = (10, 10)
font = "Zed Mono Nerd Font 10"
timeout = 5

# retroplus (retrobox dark), matching ~/.config/nvim/colors/retroplus.lua
[urgency_low]
background = "#1c1c1c"
foreground = "#928374"
frame_color = "#7c6f64"

[urgency_normal]
background = "#1c1c1c"
foreground = "#ebdbb2"
frame_color = "#83a598"

[urgency_critical]
background = "#1c1c1c"
foreground = "#ebdbb2"
frame_color = "#fb5944"
